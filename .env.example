# Copy to .env and adjust. Never commit .env.

# --- Ports (host-side) ---
API_PORT=8000
FRONTEND_PORT=3000
DB_PORT=5432

# --- Postgres ---
DB_HOST=db
DB_USER=postgres
DB_PASS=postgres
DB_NAME=porra_deportiva

# Async SQLAlchemy/asyncpg URL the backend reads (see backend/app/core/config.py).
# Inside docker-compose the host is the service name `db`.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/porra_deportiva

# --- Frontend ---
# Base URL the browser uses to reach the API.
VITE_API_URL=http://localhost:8000

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
